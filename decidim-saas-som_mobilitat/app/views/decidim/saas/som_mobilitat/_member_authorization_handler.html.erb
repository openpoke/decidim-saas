<p><%= t("decidim.authorization_handlers.sommobilitat_member.explanation") %></p>

<div class="form__wrapper">
  <% if form.send(:public_attributes)["email"].blank? %>
    <div class="callout warning">
      <p><%= t("decidim.authorization_handlers.sommobilitat_member.first_try") %></p>
    </div>
  <% end %>
  <%= form.hidden_field :email %>
  <% console %>
  <% 
    form.send(:public_attributes).map do |name, type| 
      next if name == "email" 
      next if name == "dni" && handler.attributes["email"].blank? && controller_name != "impersonations"
  %>
    <div class="field">
      <%= form.send(:input_field,name, type) %>
    </div>
  <% end %>
</div>
