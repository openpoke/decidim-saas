      <div class="md:w-1/2">
        <h2 class="h2 decorator md:text-5xl">
          <%= decidim_sanitize_admin(title_block1.presence)  || t("decidim.content_blocks.vertical_scroll.block_1.title") %>
        </h2>
        <p class="rich-text-display md:text-3xl mt-[40px] md:mt-[200px]">
            <%= decidim_sanitize_admin(description_block1.presence)  || t("decidim.content_blocks.vertical_scroll.block_1.description") %>
